{
  "name": "pruvious",
  "description": "A reliable CMS for your Nuxt site.",
  "version": "4.0.0",
  "homepage": "https://pruvious.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pruvious/pruvious.git",
    "directory": "packages/pruvious"
  },
  "author": "Muris Ceman <hello@pruvious.com>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/nuxt.config.ts"
    },
    "./kit": {
      "import": "./dist/modules/pruvious/build/kit.ts"
    }
  },
  "main": "./dist/nuxt.config.ts",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "nuxt dev .playground",
    "dev:prepare": "nuxt prepare .playground",
    "typecheck": "pnpm dev:prepare && nuxt typecheck .playground"
  },
  "dependencies": {
    "@babel/generator": "7.29.1",
    "@babel/parser": "7.29.2",
    "@babel/template": "7.28.6",
    "@babel/traverse": "7.29.0",
    "@babel/types": "7.29.0",
    "@iconify-json/tabler": "1.2.33",
    "@pruvious/i18n": "workspace:*",
    "@pruvious/orm": "workspace:*",
    "@pruvious/storage": "workspace:*",
    "@pruvious/ui": "workspace:*",
    "@pruvious/utils": "workspace:*",
    "@vueuse/core": "14.2.1",
    "@vueuse/integrations": "14.2.1",
    "accept-language-parser": "1.5.0",
    "bcrypt-ts": "8.0.1",
    "consola": "3.4.2",
    "dayjs": "1.11.20",
    "exifr": "7.1.3",
    "file-type": "22.0.1",
    "focus-trap": "8.0.1",
    "image-size": "2.0.2",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "mime": "4.1.0",
    "mlly": "1.8.2",
    "ohash": "2.0.11",
    "pathe": "2.0.3",
    "pg": "8.20.0",
    "pkg-types": "2.3.0",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-inputrules": "1.5.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.4",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "safe-stringify": "1.3.0",
