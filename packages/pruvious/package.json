  "devDependencies": {
    "@types/accept-language-parser": "1.5.8",
    "@types/babel__generator": "7.27.0",
    "@types/babel__template": "7.4.4",
    "@types/babel__traverse": "7.28.0",
    "@types/pg": "8.20.0",
    "execa": "9.6.1",
    "nitropack": "2.13.3",
    "nuxt": "4.4.2",
    "typescript": "6.0.2",
    "vue": "3.5.32",
    "vue-tsc": "3.2.6"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-dev": "1.2.4"
  }
