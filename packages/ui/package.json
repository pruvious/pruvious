{
  "name": "@pruvious/ui",
  "description": "Nuxt component library by Pruvious.",
  "version": "1.0.0",
  "homepage": "https://pruvious.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pruvious/pruvious.git",
    "directory": "packages/ui"
  },
  "author": "Muris Ceman <hello@pruvious.com>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/nuxt.config.ts",
    "./*.css": "./dist/*.css",
    "./*.vue": "./dist/*.vue",
    "./*.woff2": "./dist/*.woff2",
    "./*": "./dist/*.ts"
  },
  "main": "./dist/nuxt.config.ts",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "nuxt dev .playground",
    "dev:prepare": "nuxt prepare .playground",
    "typecheck": "pnpm dev:prepare && nuxt typecheck"
  },
  "dependencies": {
    "@floating-ui/vue": "1.1.9",
    "@iconify-json/tabler": "1.2.26",
    "@nuxt/icon": "2.2.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@pruvious/utils": "workspace:*",
    "@shikijs/langs": "3.21.0",
    "@shikijs/themes": "3.21.0",
    "@shikijs/transformers": "3.21.0",
    "@vueuse/core": "14.1.0",
    "@vueuse/integrations": "14.1.0",
    "dayjs": "1.11.19",
    "dompurify": "3.3.1",
    "focus-trap": "7.8.0",
    "marked": "17.0.1",
    "shiki": "3.21.0",
    "tippy.js": "6.3.7",
    "vue-sonner": "1.3.2"
  },
  "devDependencies": {
    "execa": "9.6.1",
    "nuxt": "4.2.2",
    "pathe": "2.0.3",
    "typescript": "5.9.3",
    "vue-tsc": "3.2.2",
    "vue": "3.5.26"
  }
}
