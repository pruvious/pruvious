{
  "name": "create-pruvious",
  "description": "Scaffold a new Nuxt project with Pruvious.",
  "version": "4.0.0-alpha.7",
  "homepage": "https://pruvious.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pruvious/pruvious.git",
    "directory": "packages/create-pruvious"
  },
  "author": "Muris Ceman <hello@pruvious.com>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "template"
  ],
  "bin": "./dist/bin.mjs",
  "main": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "unbuild",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0-alpha.9",
    "@pruvious/cli-utils": "workspace:*",
    "citty": "0.2.2",
    "execa": "9.6.1",
    "nypm": "0.6.6",
    "pathe": "2.0.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "unbuild": "3.6.1"
  }
}
