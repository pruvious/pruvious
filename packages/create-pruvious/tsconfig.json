{
  "compilerOptions": {
    "declaration": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "strict": true,
    "rootDir": "src",
    "target": "ESNext",
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
